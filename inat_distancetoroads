#Running distance to roads for inat data
library(readr)
philodiceinat <- read_csv("philodicecoordinatesinat.csv")
eurythemeinat <- read_csv("eurythemecoordinatesinat.csv")
View(eurythemeinat)


#distance to roads philodice manuscript
library(googleway)
library(readxl)
library(dplyr)
library(geosphere)

library(readxl)
philodice_datasheet <- philodiceinat
View(philodice_datasheet)

name1<- philodice_datasheet$id
lat1<- philodice_datasheet$latitude
long1<- philodice_datasheet$longitude

#trial
mydf1philodiceinat <- data.frame(site_name = (name1),
                    from_lat = (lat1),
                    from_long = (long1),
                    to_lat = (43.642342),
                    to_long = (-79.387386))

pls <- lapply(1:nrow(mydf1philodiceinat), function(x){
  
  foo <- google_directions(origin = unlist(mydf1philodiceinat[x, 2:3]),
                           destination = unlist(mydf1philodiceinat[x, 4:5]),
                           key = "", #insert API here
                           mode = "driving",
                           simplify = TRUE)
  
  ## Decode the polyline into lat/lon coordinates
  pl <- decode_pl(foo$routes$overview_polyline$points)
  
  return(pl)
})

closest_road<-list()
for(i in 1:length(pls)){
  closest_road[[i]]<-pls[[i]][1,]
}

distance_to_closest_road<-list()
for(x in 1:nrow(mydf1philodiceinat)){
  distance_to_closest_road[[x]]<-distm(c(unlist(mydf1philodiceinat[x,2:3])), c(unlist(closest_road[[x]])), fun=distHaversine)
}

distance_to_closest_road
mydf1philodiceinat$distances<-unlist(distance_to_closest_road)

mydf1philodiceinat

#distance to roads eurytheme manuscript
library(googleway)
library(readxl)
library(dplyr)
library(geosphere)

library(readxl)
eurytheme_datasheet <- eurythemeinat
View(eurytheme_datasheet)

name2<- eurytheme_datasheet$id
lat2<- eurytheme_datasheet$latitude
