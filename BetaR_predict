# Now  unscale to view original numbers for each variable
unscale <- function(scaled_values, scaled_vector) {
  mean_val <- attr(scaled_vector, "scaled:center")
  sd_val <- attr(scaled_vector, "scaled:scale")
  return(scaled_values * sd_val + mean_val)
}
