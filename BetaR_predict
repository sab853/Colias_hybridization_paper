butterfly_data_clean1$scaled_ordinal <- scale(butterfly_data_clean1$ordinal_date)

# Fit with scaled variables, regular beta
set.seed(123)
beta_orange3_scaled <- glmmTMB(
  proportion_orange ~ scaled_distances + scaled_pop_density + scaled_ordinal + scaled_2021_pop + 
    scaled_distance_tree + scaled_pedestrians +
    (1 | park_number),
  data = butterfly_data_clean1,
  family = beta_family(link = "logit"), 
  na.action = na.omit
)
summary(beta_orange3_scaled)




# r2 values
